<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloUserMAUIApp.Pages.InputPage"
             Title="Input">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
            <Label Text="Enter your username" Style="{StaticResource Headline}" />
            <Entry x:Name="UsernameEntry"
                   Placeholder="Username"
                   TextChanged="OnUsernameTextChanged" 
                   MaximumWidthRequest="300"/>
            <Button x:Name="GreetButton"
                    Text="Say hello"
                    Clicked="OnGreetClicked"
                    IsEnabled="False"
                    MaximumWidthRequest="250"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
